{
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "reply_text", "tool_calls", "needs_confirmation", "confidence", "reason_summary"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["capture", "query", "update", "clarify", "review", "ignore", "system"]
    },
    "reply_text": { "type": "string" },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "arguments"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "send_feishu_reply",
              "create_task",
              "query_today",
              "query_tomorrow",
              "query_overdue",
              "query_next_7_days",
              "update_task_status",
              "update_task_time",
              "ask_confirmation",
              "sync_bitable",
              "sync_feishu_task",
              "sync_feishu_calendar"
            ]
          },
          "arguments": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "text",
              "prompt",
              "title",
              "description",
              "due_at",
              "start_at",
              "remind_at",
              "intent",
              "domain",
              "priority",
              "energy",
              "status",
              "evidence_text",
              "confidence",
              "estimated_minutes",
              "people",
              "projects",
              "labels",
              "metadata",
              "action_id",
              "action_ids",
              "query",
              "entity_type",
              "candidates"
            ],
            "properties": {
              "text": { "type": ["string", "null"] },
              "prompt": { "type": ["string", "null"] },
              "title": { "type": ["string", "null"] },
              "description": { "type": ["string", "null"] },
              "due_at": { "type": ["string", "null"] },
              "start_at": { "type": ["string", "null"] },
              "remind_at": { "type": ["string", "null"] },
              "intent": { "type": ["string", "null"] },
              "domain": { "type": ["string", "null"] },
              "priority": { "type": ["string", "null"] },
              "energy": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] },
              "evidence_text": { "type": ["string", "null"] },
              "confidence": { "type": ["number", "null"] },
              "estimated_minutes": { "type": ["integer", "null"] },
              "people": { "type": "array", "items": { "type": "string" } },
              "projects": { "type": "array", "items": { "type": "string" } },
              "labels": { "type": "array", "items": { "type": "string" } },
              "metadata": {
                "type": "object",
                "additionalProperties": false,
                "required": ["note", "source"],
                "properties": {
                  "note": { "type": ["string", "null"] },
                  "source": { "type": ["string", "null"] }
                }
              },
              "action_id": { "type": ["string", "null"] },
              "action_ids": { "type": "array", "items": { "type": "string" } },
              "query": { "type": ["string", "null"] },
              "entity_type": { "type": ["string", "null"] },
              "candidates": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "title", "due_at"],
                  "properties": {
                    "id": { "type": ["string", "null"] },
                    "title": { "type": ["string", "null"] },
                    "due_at": { "type": ["string", "null"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "needs_confirmation": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reason_summary": { "type": "string" }
  }
}
