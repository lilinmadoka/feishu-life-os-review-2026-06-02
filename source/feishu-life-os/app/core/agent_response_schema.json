{
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "confidence", "reasoning_summary", "reply_to_user", "tool_calls"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "query_today",
        "query_tomorrow",
        "query_week",
        "query_availability",
        "create_candidates",
        "update_existing",
        "complete_item",
        "schedule_blocks",
        "smalltalk",
        "unknown"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reasoning_summary": { "type": "string" },
    "reply_to_user": { "type": "string" },
    "assistant_proposal": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string" },
        "status": { "type": "string" },
        "user_goal": { "type": "string" },
        "context_summary": { "type": "string" },
        "ai_assumptions": { "type": "array", "items": { "type": "string" } },
        "missing_info": { "type": "array", "items": { "type": "string" } },
        "candidate_plans": { "type": "array", "items": { "type": "object" } },
        "schedule_preview": { "type": "array", "items": { "type": "object" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "next_step_suggestion": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": [
        "kind",
        "status",
        "user_goal",
        "context_summary",
        "ai_assumptions",
        "missing_info",
        "candidate_plans",
        "schedule_preview",
        "risks",
        "next_step_suggestion",
        "confidence"
      ]
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool_name", "risk_level", "requires_confirmation", "arguments"],
        "properties": {
          "tool_name": {
            "type": "string",
            "enum": [
              "send_feishu_reply",
              "send_feishu_card",
              "ask_confirmation",
              "resolve_confirmation",
              "create_task_candidate",
              "confirm_task",
              "update_task",
              "complete_task",
              "cancel_task",
              "cancel_calendar_event",
              "query_tasks",
              "query_today",
              "query_tomorrow",
              "query_week",
              "query_pending_confirmations",
              "query_availability",
              "explain_time_budget_plan",
              "schedule_time_budget_plan",
              "start_plan_refinement",
              "refine_plan_draft",
              "generate_plan_schedule_confirmation",
              "confirm_plan_schedule",
              "start_habit_refinement",
              "refine_habit_plan",
              "schedule_habit_plan",
              "create_calendar_event_candidate",
              "confirm_calendar_event",
              "update_calendar_event",
              "check_conflicts",
              "create_schedule_block_candidates",
              "confirm_schedule_blocks",
              "update_schedule_block",
              "disable_schedule_block_reminders",
              "cancel_schedule_block",
              "query_schedule_blocks",
              "sync_feishu_task",
              "sync_feishu_calendar",
              "sync_bitable_audit",
              "record_agent_run",
              "record_tool_run",
              "list_recent_agent_runs",
              "list_recent_tool_runs"
            ]
          },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "requires_confirmation": { "type": "boolean" },
          "arguments": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "text": { "type": ["string", "null"] },
              "raw_text": { "type": ["string", "null"] },
              "query": { "type": ["string", "null"] },
              "day": { "type": ["string", "null"] },
              "window_start": { "type": ["string", "null"] },
              "window_end": { "type": ["string", "null"] },
              "focus": { "type": ["string", "null"] },
              "title": { "type": ["string", "null"] },
              "kind": { "type": ["string", "null"] },
              "plan_id": { "type": ["string", "null"] },
              "description": { "type": ["string", "null"] },
              "goal": { "type": ["string", "null"] },
              "category": { "type": ["string", "null"] },
              "method": { "type": ["string", "null"] },
              "frequency": { "type": ["string", "null"] },
              "byday": { "type": ["string", "null"] },
              "preferred_time": { "type": ["string", "null"] },
              "due_at": { "type": ["string", "null"] },
              "start_at": { "type": ["string", "null"] },
              "end_at": { "type": ["string", "null"] },
              "location": { "type": ["string", "null"] },
              "priority": { "type": ["string", "null"] },
              "confidence": { "type": ["number", "null"] },
              "action": { "type": ["string", "null"] },
              "confirmation_id": { "type": ["string", "null"] },
              "action_item_id": { "type": ["string", "null"] },
              "calendar_event_id": { "type": ["string", "null"] },
              "event_id": { "type": ["string", "null"] },
              "schedule_block_id": { "type": ["string", "null"] },
              "scope": { "type": ["string", "null"] },
              "reminder_enabled": { "type": ["boolean", "null"] },
              "daily_minutes": { "type": ["integer", "null"] },
              "session_minutes": { "type": ["integer", "null"] },
              "duration_days": { "type": ["integer", "null"] },
              "min_session_minutes": { "type": ["integer", "null"] },
              "buffer_minutes": { "type": ["integer", "null"] },
              "limit": { "type": ["integer", "null"] },
              "blocks": {
                "type": ["array", "null"],
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "title": { "type": "string" },
                    "recurrence_rule": { "type": "string" },
                    "start_time": { "type": "string" },
                    "end_time": { "type": "string" },
                    "timezone": { "type": "string" }
                  },
                  "required": ["title", "recurrence_rule", "start_time", "end_time", "timezone"]
                }
              },
              "planned_events": { "type": ["array", "null"], "items": { "type": "object" } },
              "attachment_refs": { "type": ["array", "null"], "items": { "type": "object" } },
              "extracted_payload": { "type": ["object", "null"] },
              "payload": { "type": ["object", "null"] },
              "patch": { "type": ["object", "null"] }
            },
            "required": [
              "text",
              "raw_text",
              "query",
              "day",
              "window_start",
              "window_end",
              "focus",
              "title",
              "kind",
              "plan_id",
              "description",
              "goal",
              "category",
              "method",
              "frequency",
              "byday",
              "preferred_time",
              "due_at",
              "start_at",
              "end_at",
              "location",
              "priority",
              "confidence",
              "action",
              "confirmation_id",
              "action_item_id",
              "calendar_event_id",
              "event_id",
              "schedule_block_id",
              "scope",
              "reminder_enabled",
              "daily_minutes",
              "session_minutes",
              "duration_days",
              "min_session_minutes",
              "buffer_minutes",
              "limit",
              "blocks",
              "planned_events",
              "attachment_refs",
              "extracted_payload",
              "payload",
              "patch"
            ]
          }
        }
      }
    }
  }
}
