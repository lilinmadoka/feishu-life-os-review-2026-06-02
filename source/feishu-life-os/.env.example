# Core
DATABASE_PATH=.data/lifeos.sqlite3
DATABASE_URL=
APP_ENV=local
TIMEZONE=Asia/Singapore
ASSISTANT_USER_DISPLAY_NAME=我
DEFAULT_MORNING_REVIEW_HOUR=7
DEFAULT_MORNING_REVIEW_MINUTE=30
DEFAULT_EVENING_REVIEW_HOUR=21
DAILY_REVIEW_FOLLOWUP_HOURS=2
ADMIN_API_TOKEN=change-me
PUBLIC_API_BASE=http://127.0.0.1:8000
PUBLIC_TUNNEL_PROTECTION=true
TUNNEL_MODE=quick
CLOUDFLARE_TUNNEL_HOSTNAME=
ATTACHMENT_STORAGE_DIR=.data/attachments
VISION_ATTACHMENT_MAX_BYTES=8388608

# Sync behavior: dry_run | bitable | task | calendar | webhook | all
FEISHU_SYNC_MODE=dry_run

# Feishu custom app credentials. Codex should fill these after creating a Feishu internal app.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_OPEN_API_BASE=https://open.feishu.cn/open-apis

# Feishu custom bot webhook for low-friction notifications to yourself or a private group.
FEISHU_BOT_WEBHOOK=
FEISHU_BOT_SECRET=
FEISHU_EVENT_VERIFICATION_TOKEN=

# Bitable tokens and table ids. See docs/FEISHU_SETUP.md and scripts/bitable_schema.json.
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_SCHEMA=project
FEISHU_BITABLE_CAPTURE_TABLE_ID=
FEISHU_BITABLE_ACTION_TABLE_ID=
FEISHU_BITABLE_REVIEW_TABLE_ID=

# Optional Feishu Task/Calendar integration
FEISHU_DEFAULT_ASSIGNEE_OPEN_ID=
FEISHU_CALENDAR_ATTENDEE_OPEN_IDS=
FEISHU_CALENDAR_ID=primary

# Agent-first provider
AGENT_STACK=legacy
AGENT_PROVIDER=codex_cli
CORE_AGENT_PROVIDER=mock_provider
AGENT_CODEX_TIMEOUT_SECONDS=300
# Prefer the Codex desktop bundled codex.exe when available. The npm codex.ps1 shim can lag behind.
CODEX_CLI_PATH=C:\Users\Administrator\AppData\Roaming\npm\codex.ps1
CODEX_WORKER_POLL_SECONDS=10

# LM Studio local OpenAI-compatible provider
# To use: set CORE_AGENT_PROVIDER=lm_studio_provider and start LM Studio Local Server.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=
LM_STUDIO_API_KEY=
LM_STUDIO_TIMEOUT_SECONDS=120
# none is most compatible with LM Studio local server; json_schema can work with some models.
LM_STUDIO_RESPONSE_FORMAT=none
# Output budget for model JSON. Context length is honored by LM Studio native /api/v1/chat.
LM_STUDIO_MAX_TOKENS=512
# LM_STUDIO_CONTEXT_LENGTH=32768
LM_STUDIO_USE_NATIVE_CHAT=false
